# =============================================================================
# ESSEN — MMCOE Canteen App
# .gitignore for Flask backend + Flutter frontend monorepo
# =============================================================================

# =============================================================================
# SECRETS — NEVER commit these
# =============================================================================
.env
.env.*
*.env
firebase-credentials.json
google-services.json          # Flutter Android Firebase config
GoogleService-Info.plist      # Flutter iOS Firebase config
service-account*.json
*credentials*.json
*secret*.json

# =============================================================================
# PYTHON / FLASK BACKEND
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover

# Exports (auto-generated by export_csv())
users.csv
orders.csv
*.csv

# Uploaded images (large binary files — serve from cloud storage in prod)
static/images/menu/*.jpg
static/images/menu/*.jpeg
static/images/menu/*.png
static/images/menu/*.gif
static/images/menu/*.webp

# SQLite (if ever used locally)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# =============================================================================
# FLUTTER / DART
# =============================================================================
# Build outputs
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Android
android/.gradle/
android/local.properties
android/app/google-services.json   # use root google-services.json instead
android/key.properties             # signing keys — NEVER commit
*.jks                              # keystore files
*.keystore

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Runner/GoogleService-Info.plist

# macOS
macos/Pods/
macos/.symlinks/

# IDEs
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db

# pubspec lock (keep for reproducible builds — comment out if you prefer)
# pubspec.lock

# =============================================================================
# RENDER / DEPLOYMENT
# =============================================================================
# Render build cache
.render-buildpacks.json

# =============================================================================
# MISC
# =============================================================================
*.bak
*.swp
*.swo
*~
.cache/
tmp/
temp/