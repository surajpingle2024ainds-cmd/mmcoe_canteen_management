# MySQL Database Connection
DATABASE_URL=mysql+pymysql://root:suraj@localhost:3306/canteen_db

# App Secret Key (used only for browser staff portal JWT — NOT for Flutter app)
SECRET_KEY=mmcoe-secret-key-2025-super-secure

# Firebase Admin SDK
# Get the real file: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Save it as firebase-credentials.json in the same folder as app.py
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=eseen-d7867

# DEV ONLY: set to true to skip Firebase token signature verification
# This lets Google Sign-In work WITHOUT a service account JSON file.
# !! Remove or set to false before deploying to production !!
FIREBASE_SKIP_VERIFY=true