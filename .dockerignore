# =============================================================================
# .dockerignore — files excluded from Docker build context
# Keeps image small and prevents secrets from leaking into the image
# =============================================================================

# Secrets — never bake into Docker image
.env
.env.*
firebase-credentials.json
*credentials*.json
*secret*.json
google-services.json
GoogleService-Info.plist

# Git
.git/
.gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Tests
.pytest_cache/
.coverage
htmlcov/

# Auto-generated exports
users.csv
orders.csv
*.csv

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Scratch / dev-only files
scratch.txt
scratch2.txt
fix_ui.py
_inspect.py
_routes.py
render_env_vars.txt

# Docs
*.md

# Misc
tmp/
temp/
.cache/
logs/
*.log
